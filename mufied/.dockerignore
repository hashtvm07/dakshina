# Keep Docker build context small and deterministic.
.gcloud
.git
.gitignore

# Dependency trees and generated output.
**/node_modules
**/dist
**/.angular
**/.firebase
**/coverage

# Local tooling metadata.
**/.vscode
**/.idea
**/.DS_Store
**/Thumbs.db

# Logs and temp files.
**/*.log
**/npm-debug.log*
**/yarn-debug.log*
**/yarn-error.log*
**/.cache
**/tmp
**/temp
