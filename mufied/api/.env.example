# Copy this file to .env and fill in your Firebase Admin credentials.
# Keep the private key on a single line with \n escapes.

FIREBASE_DATABASE_URL=https://your-project-id-default-rtdb.asia-southeast1.firebasedatabase.app/
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project-id.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----\n"

# Optional overrides
# FIREBASE_SERVICE_ACCOUNT_PATH=./config/firebase-service-account.json
# CORS_ORIGINS=https://example.com,https://admin.example.com
# SERVER_PORT=8080

# SMTP settings for automatic admission confirmation email
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-smtp-username
SMTP_PASS=your-smtp-password
SMTP_FROM="MUFIED Admissions <noreply@example.com>"
